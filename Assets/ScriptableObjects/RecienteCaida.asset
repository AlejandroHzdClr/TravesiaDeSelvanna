  dialogo:
  - nombre: Selvanna
    texto: Uff... ha sido una caida muy larga...
    retrato: {fileID: -7666730124261305028, guid: c97e7ae73a99f064881c156924f734bf, type: 3}
  - nombre: Selvanna
    texto: No creo que pueda saltar desde ahora en adelante...
    retrato: {fileID: -7666730124261305028, guid: c97e7ae73a99f064881c156924f734bf, type: 3}
  - nombre: Selvanna
    texto: "Y tampoco podr\xE9 correr... tendre que ir con cuidado"
